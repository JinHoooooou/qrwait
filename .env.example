# 이 파일을 .env 로 복사하고 실제 값으로 채우세요.
# .env 는 .gitignore 에 포함되어 있으므로 절대 커밋하지 마세요.

# PostgreSQL
DB_NAME=qrwait
DB_USERNAME=qrwait
DB_PASSWORD=

# CORS — 프론트엔드 접근 허용 도메인 (예: https://qrwait.yourdomain.com)
CORS_ALLOWED_ORIGINS=

# QR 코드에 인코딩될 베이스 URL (예: https://qrwait.yourdomain.com)
APP_BASE_URL=

# JWT 서명 시크릿 (Base64, 32바이트 이상) — openssl rand -base64 32 으로 생성
JWT_SECRET=
